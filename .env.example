# Starship HUD Environment Configuration
# Copy this file to .env and adjust values as needed

# =============================================================================
# Docker Deployment (docker-compose)
# =============================================================================

# External port for the frontend (access the HUD at http://<host>:<FRONTEND_PORT>)
FRONTEND_PORT=7891

# External port for the backend API (http://<host>:<BACKEND_PORT>/api)
BACKEND_PORT=8000

# =============================================================================
# Authentication (Optional)
# =============================================================================

# Enable authentication (requires login to access the app)
# When false, the app runs without auth and anyone can access everything
AUTH_ENABLED=false

# Secret key for signing session tokens (REQUIRED if AUTH_ENABLED=true)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-string

# Initial admin user credentials
# If ADMIN_PASSWORD is not set, a random password is generated and printed to console
ADMIN_USERNAME=admin
# ADMIN_PASSWORD=

# Session duration in days (default: 30)
SESSION_LIFETIME_DAYS=30


# Data directory (bind-mounted for easy backup and direct DB access)
# Unraid example: /mnt/user/appdata/starship-hud
# DATA_DIR=/path/to/your/data
DATA_DIR=./data

# Create demo ship (ISV Constellation) on first boot
# Set to "false" to start with an empty database
SEED_DEMO_SHIP=true

# Application version (auto-read from VERSION file during build)
# Override this only if you need a custom version string
# APP_VERSION=2026.01.0

# =============================================================================
# Container Registry (for releases)
# =============================================================================

# Container registry URL (required for `just release` and `just promote-latest`)
# Example: registry.example.com/starship-hud
# REGISTRY_URL=registry.example.com/starship-hud
#
# Image tagging strategy:
#   - Release builds publish :YYYY.MM.N and :dev tags
#   - :dev always points to the most recent published image
#   - :latest is promoted manually via `just promote-latest` (see scripts/promote-latest.sh)

# =============================================================================
# Local Development (non-Docker)
# =============================================================================

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/starship.db

# Backend dev server
HOST=0.0.0.0
PORT=8000
RELOAD=true

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
